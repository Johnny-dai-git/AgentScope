{
  "annotations": {
    "list": []
  },
  "description": "MIG-aware GPU dashboard for Lambda Labs A100 + vLLM. Shows per-MIG instance utilization, VRAM, and pod mapping. Designed for the GCP_BRANCH (Lambda Labs single-node A100 with 7x 1g.5gb MIG instances).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "GPU Temperature",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "max(DCGM_FI_DEV_GPU_TEMP)",
          "legendFormat": "Temp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 85}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "GPU Power Draw",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "Power",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 100},
              {"color": "yellow", "value": 300},
              {"color": "red", "value": 380}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "MIG Instances",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "count(count by (GPU_I_ID) (DCGM_FI_DEV_SM_CLOCK))",
          "legendFormat": "MIG count",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 4},
              {"color": "green", "value": 7}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active vLLM Pods (using MIG)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "count(count by (exported_pod) (DCGM_FI_DEV_SM_CLOCK{exported_pod!=\"\"}))",
          "legendFormat": "Pods",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "MIG \u2194 Pod Mapping (which MIG instance each vLLM pod is using)",
      "description": "Each row = one MIG instance currently bound to a workload pod. Empty = MIG idle. Watch this expand as HPA scales vllm-worker from 1 to 7.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{exported_pod!=\"\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "DCGM_FI_DRIVER_VERSION": true,
              "device": true,
              "modelName": true,
              "pci_bus_id": true,
              "UUID": true,
              "Hostname": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "service": true,
              "container": true,
              "pod": true,
              "pod_uid": true,
              "gpu": true,
              "namespace": true,
              "exported_container": true,
              "exported_namespace": true
            },
            "indexByName": {
              "GPU_I_ID": 0,
              "GPU_I_PROFILE": 1,
              "exported_pod": 2,
              "Value": 3
            },
            "renameByName": {
              "GPU_I_ID": "MIG ID",
              "GPU_I_PROFILE": "Profile",
              "exported_pod": "vLLM Pod",
              "Value": "VRAM Used (MiB)"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "VRAM Used (MiB)"},
            "properties": [
              {"id": "unit", "value": "decmbytes"},
              {"id": "custom.align", "value": "right"}
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Per-MIG Compute Activity (Graphics Engine %)",
      "description": "Real GPU utilization per MIG instance. With HPA + 7 MIG, each line is a parallel inference slot.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_PROF_GR_ENGINE_ACTIVE",
          "legendFormat": "MIG-{{GPU_I_ID}} {{exported_pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "lastNotNull", "max"]
        },
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Per-MIG Tensor Core Activity %",
      "description": "Tensor pipeline utilization (DCGM_FI_PROF_PIPE_TENSOR_ACTIVE). For fp16 inference this is the headline efficiency number.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_PROF_PIPE_TENSOR_ACTIVE",
          "legendFormat": "MIG-{{GPU_I_ID}} {{exported_pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "lastNotNull", "max"]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Per-MIG VRAM Used (KV cache + weights)",
      "description": "Each MIG slice is 5 GB. Qwen2.5-0.5B fp16 weights ~1 GB + vLLM KV cache + headroom. Watch this fill as conversations grow.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "MIG-{{GPU_I_ID}} {{exported_pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "lastNotNull", "max"]
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Per-MIG DRAM Active %",
      "description": "Memory subsystem activity. High DRAM_ACTIVE means the workload is memory-bandwidth bound (typical for small-batch LLM decode).",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_PROF_DRAM_ACTIVE",
          "legendFormat": "MIG-{{GPU_I_ID}} {{exported_pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "lastNotNull", "max"]
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["nvidia", "mig", "a100", "vllm", "lambda-labs"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Lambda A100 / MIG / vLLM",
  "uid": "lambda-mig-vllm",
  "version": 1,
  "weekStart": ""
}
